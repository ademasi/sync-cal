{
  "env": {
    "browser": true,
    "es2022": true,
    "webextensions": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "script"
  },
  "globals": {
    "ChromeUtils": "readonly",
    "Services": "readonly",
    "Cc": "readonly",
    "Ci": "readonly",
    "Cr": "readonly",
    "Components": "readonly",
    "globalThis": "readonly"
  },
  "rules": {
    "no-unused-vars": ["error", { "argsIgnorePattern": "^_", "varsIgnorePattern": "^(isOwnCalendar|unwrapCalendar|getResolvedCalendarById|getCachedCalendar|isCachedCalendar|convertCalendar|propsToItem|convertItem|convertAlarm|setupE10sBrowser)$" }],
    "semi": ["error", "always"],
    "quotes": ["error", "double", { "avoidEscape": true }],
    "indent": ["error", 2, { "SwitchCase": 1 }],
    "no-console": "off"
  },
  "overrides": [
    {
      "files": ["experiments/**/*.js"],
      "parserOptions": {
        "sourceType": "script"
      },
      "globals": {
        "MatchPattern": "readonly",
        "MatchGlob": "readonly"
      },
      "rules": {
        "no-redeclare": "off"
      }
    },
    {
      "files": ["**/*.test.js", "jest.config.js"],
      "env": {
        "jest": true,
        "node": true
      }
    }
  ]
}
